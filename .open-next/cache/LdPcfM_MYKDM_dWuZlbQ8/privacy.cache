/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"4. Sharing Your Information\"}],[[\"$\",\"p\",null,{\"children\":\"We do not sell your personal data. We may share data in the following limited circumstances:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-2 mt-3\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Service Providers:\"}],\" Cloud hosting (AWS/Firebase), payment processors (MTN MoMo API, Paystack), analytics providers (Mixpanel/Amplitude), and customer support tools — all bound by data processing agreements.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"University Partners:\"}],\" For student verification only, with your consent.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Other Users:\"}],\" Public profile information, marketplace listings, posts, and UniClips you choose to make public.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Legal Authorities:\"}],\" Where required by Ghanaian law (e.g., court orders, the Data Protection Commission, the Ghana Police Service) or to protect the rights and safety of users.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Business Transfers:\"}],\" In the event of a merger or acquisition, your data may be transferred to the new entity, which will be bound by this policy.\"]}]]}]]]}]\n16:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"5. International Data Transfers\"}],[\"$\",\"p\",null,{\"children\":\"UniLoomy is based in Ghana. Our service providers may process data outside of Ghana, including in the European Economic Area (EEA), the United Kingdom, and the United States. Where such transfers occur, we ensure appropriate safeguards are in place in accordance with Ghana's Data Protection Act (s. 43) and GDPR Chapter V, including Standard Contractual Clauses (SCCs) or equivalent mechanisms.\"}]]}]\n17:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"6. Data Retention\"}],[[\"$\",\"p\",null,{\"children\":\"We retain your personal data for as long as your account is active or as needed to provide services. Specifically:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-2 mt-3\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Account data\"}],\" — retained for the duration of your account plus 6 months after deletion requests.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Transaction records\"}],\" — retained for 7 years to comply with Ghana Revenue Authority (GRA) requirements and the Companies Act financial records obligations.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Support communications\"}],\" — retained for 3 years.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Usage logs\"}],\" — anonymised after 12 months.\"]}]]}]]]}]\n18:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"7. Your Rights\"}],[[\"$\",\"p\",null,{\"children\":\"Under Ghana's Data Protection Act, 2012, and applicable international law, you have the right to:\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-2 gap-3 mt-4\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Access\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"Request a copy of your personal data we hold.\"}]]}],[\"$\",\"div\",\"1\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Rectification\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"Correct inaccurate or incomplete data.\"}]]}],[\"$\",\"div\",\"2\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Erasure\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"Request deletion of your data (subject to legal obligations).\"}]]}],[\"$\",\"div\",\"3\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Portability\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"Receive your data in a structured, machine-readable format.\"}]]}],[\"$\",\"div\",\"4\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Object\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"Object to processing based on legitimate interests.\"}]]}],[\"$\",\"div\",\"5\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Restriction\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"Request that we limit how we use your data.\"}]]}],[\"$\",\"div\",\"6\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Withdraw Consent\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"Withdraw consent for consent-based processing at any time.\"}]]}],[\"$\",\"div\",\"7\",{\"className\":\"p-4 rounded-xl bg-white/[0.02] border border-white/5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-white text-xs uppercase tracking-widest mb-1\",\"children\":[\"Right to \",\"Lodge a Complaint\"]}],[\"$\",\"p\",null,{\"className\":\"text-xs\",\"children\":\"File a complaint with Ghana's Data Protection Commission (DPC).\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"mt-4\",\"children\":[\"To exercise any right, email \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"privacy@uniloomy.com\"}],\". We will respond within 30 days, as required by the DPA 2012.\"]}]]]}]\n19:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"8. Security\"}],[[\"$\",\"p\",null,{\"children\":\"We implement industry-standard technical and organisational measures to protect your data including:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-2 mt-3\",\"children\":[[\"$\",\"li\",null,{\"children\":\"AES-256 encryption at rest and TLS 1.3 in transit.\"}],[\"$\",\"li\",null,{\"children\":\"Bcrypt hashing for passwords.\"}],[\"$\",\"li\",null,{\"children\":\"Role-based access controls for internal staff.\"}],[\"$\",\"li\",null,{\"children\":\"Regular security audits and penetration testing.\"}],[\"$\",\"li\",null,{\"children\":\"Multi-factor authentication for administrative systems.\"}]]}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"No system is completely secure. In the event of a data breach that affects your rights, we will notify you and the Ghana Data Protection Commission within 72 hours, as required by Act 843.\"}]]]}]\n1a:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"9. Cookies and Tracking\"}],[[\"$\",\"p\",null,{\"children\":\"We use the following types of cookies and tracking technologies:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-2 mt-3\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Strictly Necessary:\"}],\" Authentication tokens and session management. Cannot be disabled.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Analytics:\"}],\" Understanding how users interact with our platform (can be disabled in App Settings).\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Marketing:\"}],\" Personalised ads and promotions — only with your explicit consent.\"]}]]}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"You can manage cookie preferences in your account settings or via your browser/device settings.\"}]]]}]\n1b:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"10. Children's Privacy\"}],[\"$\",\"p\",null,{\"children\":[\"UniLoomy is designed for university students aged 16 and over. We do not knowingly collect personal data from children under 16. If we learn that we have inadvertently collected data from a child under 16, we will delete it promptly. If you believe a minor has provided us data, contact us at \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"privacy@uniloomy.com\"}],\".\"]}]]}]\n1c:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"11. Changes to This Policy\"}],[\"$\",\"p\",null,{\"children\":\"We may update this Privacy Policy from time to time. We will notify you of material changes via in-app notification or email at least 14 days before changes take effect. The \\\"Last Updated\\\" date at the top reflects the most recent version. Continued use of the Service after the effective date constitutes acceptance of the updated policy.\"}]]}]\n1d:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"12. Contact Us\"}],[\"$\",\"div\",null,{\"className\":\"p-6 rounded-2xl bg-white/[0.03] border border-white/5 space-y-2\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"UniLoomy Technologies Ltd\"}]}],[\"$\",\"p\",null,{\"children\":\"Ghana\"}],[\"$\",\"p\",null,{\"children\":[\"Email: \",[\"$\",\"a\",null,{\"href\":\"mailto:privacy@uniloomy.com\",\"className\":\"text-blue-400 underline\",\"children\":\"privacy@uniloomy.com\"}]]}],[\"$\",\"p\",null,{\"children\":[\"For DPC complaints (Ghana): \",[\"$\",\"a\",null,{\"href\":\"https://www.dataprotection.org.gh\",\"target\":\"_blank\",\"rel\":\"noreferrer\",\"className\":\"text-blue-400 underline\",\"children\":\"dataprotection.org.gh\"}]]}]]}]]}]\n23:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n26:I[27201,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"IconMark\"]\n20:null\n25:[[\"