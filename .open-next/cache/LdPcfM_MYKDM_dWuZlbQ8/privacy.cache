nd interests.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Financial Data:\"}],\" For marketplace and gig transactions — mobile money account details (e.g., MTN MoMo, Vodafone Cash, AirtelTigo Money), payment history. We do not store full card numbers.\"]}],\"$L4\",\"$L5\"]}]]}],\"$L6\",\"$L7\"]]}],\"$L8\",\"$L9\",\"$La\",\"$Lb\",\"$Lc\",\"$Ld\",\"$Le\",\"$Lf\",\"$L10\",\"$L11\"]}],\"$L12\"]}]]}],[\"$L13\"],\"$L14\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"LdPcfM_MYKDM_dWuZlbQ8\"}\n4:[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Content:\"}],\" Posts, comments, stories, UniClips, study materials, marketplace listings, gig postings, and messages you create.\"]}]\n5:[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Communication:\"}],\" Emails or messages you send to our support team.\"]}]\n6:[\"$\",\"div\",null,{\"className\":\"mt-5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-black text-white text-sm uppercase tracking-wider mb-2\",\"children\":\"2.2 Information Collected Automatically\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-2 mt-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Device Information:\"}],\" Device type, operating system, unique device identifiers, mobile network, and IP address.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Usage Data:\"}],\" Features used, pages visited, time spent, app interactions, search queries, and click patterns.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Location Data:\"}],\" Approximate location derived from IP address. Precise GPS location only with your explicit consent (e.g., for housing listings 