ceptance of the updated policy.\"}]]}]\n1d:[\"$\",\"div\",null,{\"className\":\"border-t border-white/5 pt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl md:text-2xl font-black text-white mb-5\",\"children\":\"12. Contact Us\"}],[\"$\",\"div\",null,{\"className\":\"p-6 rounded-2xl bg-white/[0.03] border border-white/5 space-y-2\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"UniLoomy Technologies Ltd\"}]}],[\"$\",\"p\",null,{\"children\":\"Ghana\"}],[\"$\",\"p\",null,{\"children\":[\"Email: \",[\"$\",\"a\",null,{\"href\":\"mailto:privacy@uniloomy.com\",\"className\":\"text-blue-400 underline\",\"children\":\"privacy@uniloomy.com\"}]]}],[\"$\",\"p\",null,{\"children\":[\"For DPC complaints (Ghana): \",[\"$\",\"a\",null,{\"href\":\"https://www.dataprotection.org.gh\",\"target\":\"_blank\",\"rel\":\"noreferrer\",\"className\":\"text-blue-400 underline\",\"children\":\"dataprotection.org.gh\"}]]}]]}]]}]\n23:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n26:I[27201,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"IconMark\"]\n20:null\n25:[[\"$\",\"title\",\"0\",{\"children\":\"Privacy Policy | UniLoomy | UniLoomy\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"UniLoomy's Privacy Policy — how we collect, use, and protect your data.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"application-name\",\"content\":\"UniLoomy\"}],[\"$\",\"link\",\"3\",{\"rel\":\"author\",\"href\":\"https://uniloomy.com\"}],[\"$\",\"meta\",\"4\",{\"name\":\"author\",\"content\":\"UniLoomy Technologies Ltd\"}],[\"$\",\"link\",\"5\",{\"rel\":\"manifest\",\"href\":\"/manifest.json\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"meta\",\"6\",{\"name\":\"generator\",\"content\":\"Next.js\"}],[\"$\",\"meta\",\"7\",{\"name\":\"keywords\",\"content\":\"UniLoomy,university app Gh