nt=\"Next.js\"/><meta name=\"keywords\" content=\"UniLoomy,university app Ghana,student app Ghana,campus app,student marketplace Ghana,student gigs Ghana,study tools Ghana,UniClips,campus social app,Looms rewards,University of Ghana app,KNUST app,student housing Ghana,learn earn connect,Ghanaian student platform\"/><meta name=\"referrer\" content=\"origin-when-cross-origin\"/><meta name=\"creator\" content=\"UniLoomy Technologies Ltd\"/><meta name=\"publisher\" content=\"UniLoomy Technologies Ltd\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"/><meta name=\"category\" content=\"Education, Social, Marketplace\"/><link rel=\"canonical\" href=\"https://uniloomy.com\"/><meta name=\"google-site-verification\" content=\"REPLACE_WITH_GOOGLE_SEARCH_CONSOLE_KEY\"/><meta property=\"og:title\" content=\"UniLoomy — Learn Smarter. Earn Bigger. Connect Deeper.\"/><meta property=\"og:description\" content=\"Ghana&#x27;s all-in-one university super-app. Study smarter with AI tools, earn Looms rewards, use the student marketplace, find campus gigs, watch UniClips, and connect with students across universities.\"/><meta property=\"og:url\" content=\"https://uniloomy.com\"/><meta property=\"og:site_name\" content=\"UniLoomy\"/><meta property=\"og:locale\" content=\"en_GH\"/><meta property=\"og:image\" content=\"https://uniloomy.com/og-image.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"UniLoomy — The Super App for University Students\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:site\" content=\"@uniloomy\"/><meta name=\"twitter:creator\" content=\"@uniloomy\"/><meta name=\"twitter:title\" content=\"UniLoomy — Learn Smarter. Earn Bigger. Connect Deeper.\"/><meta name=\"twitter:description\" content=\"Ghana&#x27;s all-in-one university super-app. AI study tools, student marketplace, campus gigs, UniClips, Looms rewards, and more.\"/><meta name=\"twitter:image\" content=\"https://uniloomy.com/og-image.png\"/><link rel=\"shortcut icon\" href=\"/icon.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/icon.png\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/apple-icon.png\" type=\"image/png\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"UniLoomy\",\"url\":\"https://uniloomy.com\",\"logo\":\"https://uniloomy.com/icon.png\",\"description\":\"Ghana's all-in-one university super-app for learning, earning, and connecting.\",\"address\":{\"@type\":\"PostalAddress\",\"addressCountry\":\"GH\"},\"sameAs\":[\"https://twitter.com/uniloomy\",\"https://linkedin.com/company/uniloomy\"]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"MobileApplication\",\"name\":\"UniLoomy\",\"operatingSystem\":\"iOS, Android\",\"applicationCategory\":\"EducationApplication\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"GHS\"},\"description\":\"UniLoomy is the all-in-one university super-app for Ghanaian students — AI study tools, marketplace, gigs, social feed, UniClips, and Looms rewards.\"}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><main class=\"min-h-screen bg-[#020617] text-white\"><nav class=\"sticky top-0 z-50 w-full border-b border-white/5 bg-[#020617]/80 backdrop-blur-xl px-6 py-4\"><div class=\"max-w-4xl mx-auto flex items-center justify-between\"><a href=\"/\"><img alt=\"UniLoomy\" loading=\"lazy\" width=\"120\" height=\"32\" decoding=\"async\" data-nimg=\"1\" class=\"h-6 w-auto\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fassets%2Funiloomy.png&amp;w=128&amp;q=75 1x, /_next/image?url=%2Fassets%2Funiloomy.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Fassets%2Funiloomy.png&amp;w=256&amp;q=75\"/></a><a class=\"text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-white transition-colors\" href=\"/\">← Back to Home</a></div></nav><div class=\"max-w-4xl mx-auto px-6 py-16 md:py-24\"><div class=\"mb-16\"><div class=\"inline-block px-3 py-1 rounded-full bg-blue-900/30 border border-blue-700/30 text-[10px] font-black tracking-widest text-blue-400 uppercase mb-6\">Legal Document</div><h1 class=\"text-4xl md:text-6xl font-black mb-4 tracking-tight\">Terms of Service</h1><p class=\"text-slate-400 text-sm\">Last Updated: <!-- -->March 29, 2026</p><div class=\"mt-8 p-6 rounded-2xl bg-white/[0.03] border border-white/5\"><p class=\"text-slate-300 leading-relaxed text-sm\">Please read these Terms of Service (&quot;Terms&quot;) carefully before using UniLoomy. By creating an account or accessing the Service, you agree to be bound by these Terms. These Terms constitute a legally binding agreement between you and <strong>UniLoomy Technologies Ltd</strong>, a company incorporated under the Companies Act, 2019 (Act 992) of Ghana. If you do not agree, you must not use the Service.</p></div></div><div class=\"space-y-10 text-sm leading-relaxed text-slate-300\"><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">1. Eligibility</h2><p>You must be at least <strong class=\"text-white\">16 years old</strong> and a currently enrolled or recently graduated university student to use UniLoomy. By registering, you confirm that:</p><ul class=\"list-disc pl-5 space-y-2 mt-3\"><li>You are at least 16 years of age.</li><li>You have the legal capacity to enter into a binding contract under Ghanaian law or the law of your jurisdiction.</li><li>You are affiliated with a recognised university or tertiary institution.</li><li>All registration information you submit is accurate and truthful.</li></ul><p class=\"mt-3\">UniLoomy reserves the right to verify your student status and suspend accounts that fail verification.</p></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">2. Account Registration and Security</h2><ul class=\"list-disc pl-5 space-y-2\"><li>You are responsible for maintaining the confidentiality of your password and account credentials.</li><li>You agree to notify us immediately at <strong class=\"text-white\">support@uniloomy.com</strong> if you suspect any unauthorised access to your account.</li><li>UniLoomy is not liable for any loss resulting from a third party using your account without your permission where you have failed to take reasonable security precautions.</li><li>You may only hold one account on UniLoomy. Creating multiple accounts to circumvent a suspension is a material breach of these Terms.</li></ul></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">3. Acceptable Use Policy</h2><p>You agree to use the Service lawfully and in good faith. You <strong class=\"text-white\">must not</strong>:</p><ul class=\"list-disc pl-5 space-y-2 mt-3\"><li>Post content that is unlawful, defamatory, obscene, threatening, or violates another person&#x27;s rights.</li><li>Share, distribute, or reproduce copyrighted material without appropriate authorisation.</li><li>Engage in fraud, misrepresentation, or impersonation of any person or entity.</li><li>Use the platform to conduct scams, pyramid schemes, or any fraudulent commercial activity.</li><li>Harass, bully, or abuse any other user — including through the Anonymous Discussions feature.</li><li>Post, list, or solicit items that are illegal under Ghanaian law (e.g., narcotics, unlicensed firearms, counterfeit goods).</li><li>Interfere with or disrupt the Service&#x27;s infrastructure, networks, or security.</li><li>Use automated tools (bots, scrapers) to access the Service without prior written consent.</li><li>Use the Service to promote hate speech, discrimination, or violence against any group.</li></ul><p class=\"mt-4\">Violation of this Acceptable Use Policy may result in immediate account suspension or permanent termination, and may be reported to relevant authorities under the <strong class=\"text-white\">Electronic Transactions Act, 2008 (Act 772)</strong> and the <strong class=\"text-white\">Cybersecurity Act, 2020 (Act 1038)</strong> of Ghana.</p></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">4. Marketplace, Gigs &amp; Transactions</h2><ul class=\"list-disc pl-5 space-y-2\"><li>UniLoomy provides a platform for peer-to-peer transactions. We are not a party to any transaction between buyers and sellers or employers and service providers.</li><li>All listings must be accurate, honest, and compliant with our Acceptable Use Policy.</li><li>UniLoomy does not guarantee the quality, safety, or legality of items listed or services offered.</li><li>Payment disputes must first be raised through UniLoomy&#x27;s in-app dispute resolution system. UniLoomy&#x27;s decisions in such disputes are final and binding on both parties.</li><li>All financial transactions on the platform are subject to Ghana&#x27;s <strong class=\"text-white\">Payment Systems and Services Act, 2019 (Act 987)</strong>.</li><li>Users are solely responsible for any taxes applicable to their earnings through the platform in accordance with Ghana Revenue Authority (GRA) regulations.</li></ul></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">5. Looms (Rewards Points)</h2><ul class=\"list-disc pl-5 space-y-2\"><li>Looms are UniLoomy&#x27;s in-platform reward points. They have no cash value and cannot be transferred, sold, or exchanged for currency outside of the defined redemption mechanisms within the App.</li><li>UniLoomy reserves the right to modify, suspend, or discontinue the Looms programme with 30 days&#x27; notice to affected users.</li><li>Looms obtained through fraudulent activity will be forfeited immediately and may result in account suspension.</li><li>Unredeemed Looms expire 12 months after your last account activity.</li></ul></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">6. User-Generated Content</h2><p>You retain ownership of content you post on UniLoomy (&quot;User Content&quot;). By posting User Content, you grant UniLoomy Technologies Ltd a <strong class=\"text-white\">worldwide, non-exclusive, royalty-free, sublicensable licence</strong> to use, reproduce, modify, adapt, publish, translate, distribute, and display such content for the purpose of operating and promoting the Service.</p><p class=\"mt-3\">You represent and warrant that:</p><ul class=\"list-disc pl-5 space-y-2 mt-2\"><li>You own or have the right to post the User Content.</li><li>The User Content does not infringe any third party&#x27;s intellectual property, privacy, or other rights.</li><li>The User Content complies with our Acceptable Use Policy and all applicable laws.</li></ul><p class=\"mt-3\">UniLoomy may remove any User Content at our sole discretion without prior notice if it violates these Terms or applicable law.</p></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">7. Intellectual Property</h2><p>All platform content, branding, software, design, and trademarks belonging to UniLoomy are protected by intellectual property laws of Ghana and international treaties. You are granted a limited, non-exclusive, non-transferable licence to use the Service for its intended purpose. You may not:</p><ul class=\"list-disc pl-5 space-y-2 mt-3\"><li>Copy, modify, or distribute any part of the Service or its content without express written permission.</li><li>Reverse-engineer, decompile, or attempt to extract the source code of the application.</li><li>Use UniLoomy&#x27;s brand name, logo, or trademarks without prior written consent.</li></ul></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">8. Housing Listings</h2><ul class=\"list-disc pl-5 space-y-2\"><li>UniLoomy is a platform for listing student accommodation. We are not a landlord, real estate agent, or property manager.</li><li>UniLoomy does not verify the physical condition, legal title, or safety of any listed property.</li><li>You are strongly advised to physically inspect any property and review all documents before entering into a rental or purchase agreement.</li><li>Posting fraudulent or misleading housing listings is a criminal offence under Ghanaian law and will result in immediate account termination and reporting to the Ghana Police Service.</li></ul></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">9. Termination</h2><p>UniLoomy may suspend or terminate your account at any time, with or without notice, for:</p><ul class=\"list-disc pl-5 space-y-2 mt-3\"><li>Any violation of these Terms.</li><li>Engagement in fraudulent, abusive, or illegal activity.</li><li>Prolonged inactivity (more than 24 months).</li><li>At our discretion to protect the safety of the community.</li></ul><p class=\"mt-3\">You may terminate your account at any time via the in-app &quot;Delete Account&quot; option in Settings. Upon termination, your right to use the Service ceases immediately. Data retention obligations are governed by our Privacy Policy.</p></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">10. Disclaimers and Limitation of Liability</h2><div class=\"p-4 rounded-xl bg-amber-900/10 border border-amber-700/20 text-amber-300/80 text-xs mb-4\">⚠️ Please read this section carefully as it limits UniLoomy&#x27;s legal liability.</div><p><strong class=\"text-white\">10.1 As-Is Service.</strong> The Service is provided &quot;as is&quot; and &quot;as available&quot; without warranty of any kind, express or implied, including merchantability, fitness for a particular purpose, or non-infringement.</p><p class=\"mt-3\"><strong class=\"text-white\">10.2 Limitation of Liability.</strong> To the fullest extent permitted by Ghanaian law, UniLoomy&#x27;s total liability to you for any claim arising from your use of the Service shall not exceed the amount you paid to UniLoomy (if any) in the six (6) months preceding the claim. UniLoomy is not liable for indirect, incidental, consequential, or punitive damages.</p><p class=\"mt-3\"><strong class=\"text-white\">10.3 Third-Party Actions.</strong> UniLoomy is not responsible for the actions of other users, including transactions, disputes, or harmful content. Your interaction with other users is at your own risk.</p></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">11. Indemnity</h2><p>You agree to indemnify, defend, and hold harmless UniLoomy Technologies Ltd, its directors, officers, employees, and agents from any claims, damages, liabilities, costs, and expenses (including reasonable legal fees) arising from:</p><ul class=\"list-disc pl-5 space-y-2 mt-3\"><li>Your use of or access to the Service.</li><li>Your violation of these Terms.</li><li>Your violation of any rights of a third party, including intellectual property, privacy, or consumer rights.</li><li>Any User Content you post on the platform.</li></ul></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">12. Governing Law and Dispute Resolution</h2><p>These Terms are governed by and construed in accordance with the laws of the <strong class=\"text-white\">Republic of Ghana</strong>. Any dispute arising under these Terms shall be subject to the exclusive jurisdiction of the courts of Ghana.</p><p class=\"mt-3\"><strong class=\"text-white\">Mediation First:</strong> Before initiating formal legal proceedings, both parties agree to attempt in good faith to resolve any dispute through mediation, in accordance with the <strong class=\"text-white\">Alternative Dispute Resolution Act, 2010 (Act 798)</strong> of Ghana.</p></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">13. Changes to These Terms</h2><p>We may update these Terms from time to time. Material changes will be communicated via in-app notification or email at least 14 days before taking effect. Continued use of the Service after such notification constitutes your acceptance of the updated Terms.</p></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">14. Miscellaneous</h2><ul class=\"list-disc pl-5 space-y-2\"><li><strong class=\"text-white\">Severability:</strong> If any provision of these Terms is found to be unenforceable, the remaining provisions shall continue in full force.</li><li><strong class=\"text-white\">Entire Agreement:</strong> These Terms, together with our Privacy Policy, constitute the entire agreement between you and UniLoomy.</li><li><strong class=\"text-white\">Waiver:</strong> Failure by UniLoomy to enforce any provision shall not constitute a waiver of that provision.</li><li><strong class=\"text-white\">Assignment:</strong> UniLoomy may assign these Terms in connection with a merger or acquisition. You may not assign your rights under these Terms without our consent.</li></ul></div><div class=\"border-t border-white/5 pt-10\"><h2 class=\"text-xl md:text-2xl font-black text-white mb-5\">15. Contact Us</h2><div class=\"p-6 rounded-2xl bg-white/[0.03] border border-white/5 space-y-2\"><p><strong class=\"text-white\">UniLoomy Technologies Ltd</strong></p><p>Ghana</p><p>Email: <a href=\"mailto:legal@uniloomy.com\" class=\"text-blue-400 underline\">legal@uniloomy.com</a></p><p>Support: <a href=\"mailto:support@uniloomy.com\" class=\"text-blue-400 underline\">support@uniloomy.com</a></p></div></div></div><div class=\"mt-20 pt-10 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-slate-600 font-bold uppercase tracking-widest\"><span>© <!-- -->2026<!-- --> UniLoomy Technologies Ltd. Ghana</span><div class=\"flex gap-6\"><a class=\"hover:text-white transition-colors\" href=\"/privacy\">Privacy Policy</a><a class=\"text-blue-500\" href=\"/terms\">Terms of Service</a><a class=\"hover:text-white transition-colors\" href=\"/\">Home</a></div></div></div></main><!--$--><!--/$--><script src=\"/_next/static/chunks/045g~0~zva_mv.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n4:I[22016,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/11m0jj2zyf9g~.js\\\"],\\\"\\\"]\\n5:I[85437,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/11m0jj2zyf9g~.js\\\"],\\\"Image\\\"]\\nf:I[68027,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/0wrbb8ta83d_a.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.0.q-h669a_dqa.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.16t1db8_9y2o~.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"t